{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "fs:allow-stat",
    "fs:scope-home-recursive",
    "fs:scope-download-recursive",
    "fs:scope-desktop-recursive"
  ]
}
